# Copy this file to .env and fill in your real values.
# .env is git-ignored and will never be committed.

# Flask
SECRET_KEY=change-this-to-a-long-random-string

# MySQL
SECRET_KEY=change-this-to-a-long-random-string
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DB=traffic_db
MYSQL_PORT=3306